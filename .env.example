# ─── Client-side env vars (VITE_* are compiled into JS bundle) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# VITE_API_URL — tidak diperlukan lagi, frontend pake relative path (/api/*)
# Vercel serverless functions handle /api/*, Vite proxy handle local dev
