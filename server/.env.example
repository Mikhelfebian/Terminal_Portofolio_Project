# Server
PORT=3001
NODE_ENV=development

# Allowed frontend origin (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# ── Secrets (never share these) ──
# GitHub personal access token (public_repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# OpenRouter API key for AI chat
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Admin panel password (min 12 chars recommended)
ADMIN_PASSWORD=your-secure-admin-password

# JWT secret for admin session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-random-64-hex-chars

# Supabase service_role key (for admin portfolio writes)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9xxxxxxxxxxxx

# Optional: Direct SMTP for contact form (instead of Formspree)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# CONTACT_TO=you@example.com
